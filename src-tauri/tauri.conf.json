{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrossPost Desktop",
  "version": "0.1.0",
  "identifier": "de.andrii-it.crosspost",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CrossPost Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "CrossPost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "sidecars/*"
    ],
    "externalBin": [
      "sidecars/python-sidecar",
      "sidecars/evolution-api"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:crosspost.db"]
    },
    "stronghold": {
      "passwordHashAlgorithm": "argon2id"
    },
    "autostart": {
      "mobile": false,
      "desktop": true
    }
  }
}
